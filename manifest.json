{
  "manifest_version": 3,
  "name": "Trizup Whats Connect",
  "version": "0.2.2",
  "description": "Conecta seu número ao Trizup com segurança e sem QR Code de API, com sua aprovação.",
  "action": {
    "default_title": "Abrir Trizup Whats Connect",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*.uazapi.com/*",
    "https://painel.trizup.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["autofill.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.uazapi.com/*", "https://painel.trizup.app/*"],
      "js": ["app-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
